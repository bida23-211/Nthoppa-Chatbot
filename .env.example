# ============================================================
# NTHOPPA WHATSAPP CHATBOT — Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# ----- Meta / WhatsApp Business API -----
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_permanent_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here

# ----- Webhook Verification -----
# This must match what you enter in the Meta App Dashboard webhook settings
VERIFY_TOKEN=nthoppa_verify_token_123

# ----- Server -----
PORT=3000
